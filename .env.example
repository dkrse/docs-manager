# Database connection (required)
DATABASE_URL=postgresql://postgres:your_password@localhost/documents

# JWT signing key (required for persistent sessions)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# File storage path
UPLOAD_DIR=/opt/apps/document-manager/uploads

# Max upload file size in bytes (default 100MB)
MAX_UPLOAD_SIZE=104857600

# Session duration in minutes (default 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Container timezone
TZ=Europe/Bratislava
